# Supabase
SUPABASE_URL=https://supabase-api.swipego.app
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Auth
JWT_SECRET=generate_a_random_64_char_string_here
JWT_REFRESH_SECRET=generate_another_random_64_char_string_here

# Encryption (for credentials storage)
ENCRYPTION_KEY=generate_a_random_32_byte_hex_string_here

# Initial admin (used by seed-admin.js)
ADMIN_EMAIL=admin@swipego.app
ADMIN_PASSWORD=change_this_password

# Server
PORT=3000
NODE_ENV=production

# Google Business Profile (OAuth — réponse automatique aux avis)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# Google Places API (bloc avis Google sur le site)
# Activer Places API sur https://console.cloud.google.com
# Trouver les Place IDs : node scripts/find-place-ids.js
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# Format : ChIJ... (Place ID standard) ou cid:DECIMAL (fallback)
GOOGLE_PLACE_IDS=ChIJxxx,ChIJyyy
