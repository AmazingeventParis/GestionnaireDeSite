# Supabase
SUPABASE_URL=https://supabase-api.swipego.app
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Auth
JWT_SECRET=generate_a_random_64_char_string_here
JWT_REFRESH_SECRET=generate_another_random_64_char_string_here

# Encryption (for credentials storage)
ENCRYPTION_KEY=generate_a_random_32_byte_hex_string_here

# Initial admin (used by seed-admin.js)
ADMIN_EMAIL=admin@swipego.app
ADMIN_PASSWORD=change_this_password

# SMTP (contact form)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=contact@shootnbox.fr
SMTP_PASS=your_smtp_password_here
CONTACT_EMAIL=contact@shootnbox.fr

# Server
PORT=3000
NODE_ENV=production
